/// Tests for quaternion lift and dicyclic groups


import quaternion;

#[test]
fn test_quaternion_identity() {
    let id = quaternion.Quaternion::identity();
    let q = quaternion.Quaternion::new(1.0, 2.0, 3.0, 4.0);
    assert!(id.mul(&q).approx_eq(&q, 0.0000000001));
}

#[test]
fn test_dicyclic_order() {
    let g = quaternion.DicyclicGroup::new(4);
    assert_eq!(g.order(), 16);
}

#[test]
fn test_double_cover() {
    for n in 2..=8 {
        let g = quaternion.DicyclicGroup::new(n);
        assert!(quaternion.verify_double_cover(&g));
    }
}

#[test]
fn test_generator_relations() {
    let g = quaternion.DicyclicGroup::new(4);

    // a^{2n} = 1
    let a = quaternion.dicyclic_element(&g, 1, false);
    var a_power = a;
    for _ in 1..8 {
        a_power = a_power.q.mul(&a.q);
    }
    assert!(a_power.q.approx_eq(&quaternion.Quaternion::identity(), 0.0000000001));

    // b^2 = a^n
    let b = quaternion.dicyclic_element(&g, 0, true);
    let b2 = quaternion.DicyclicElement { q: b.q.mul(&b.q) };
    let an = quaternion.dicyclic_element(&g, g.n, false);
    assert!(b2.q.approx_eq(&an.q, 0.0000000001));
}
