{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agourakis82/darwin-atlas/epistemic/atlas_knowledge",
  "title": "Atlas Knowledge Record",
  "description": "Demetrios epistemic Knowledge[T] record for Atlas pipeline outputs",
  "type": "object",
  "required": ["record_type", "metric_name", "value", "validity", "provenance"],
  "additionalProperties": true,
  "properties": {
    "record_type": {
      "type": "string",
      "enum": [
        "replicon_metric",
        "window_metric",
        "approx_symmetry",
        "dicyclic_lift",
        "quaternion_result",
        "kmer_metric",
        "skew_metric",
        "ir_metric",
        "replichore_metric"
      ],
      "description": "Classification of the knowledge record"
    },
    "metric_name": {
      "type": "string",
      "description": "Name of the metric (e.g., gc_fraction, orbit_ratio, dmin_over_L)"
    },
    "value": {
      "description": "The metric value (number, string, or structured object)",
      "oneOf": [
        {"type": "number"},
        {"type": "string"},
        {"type": "boolean"},
        {"type": "object"}
      ]
    },
    "epsilon": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Error bound / uncertainty. Null if unknown, 0 if deterministic exact."
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1,
      "description": "Epistemic confidence in [0,1]. Null if unknown, 1.0 if deterministic."
    },
    "validity": {
      "type": "object",
      "required": ["holds"],
      "properties": {
        "holds": {
          "type": "boolean",
          "description": "Whether validity predicate is satisfied"
        },
        "predicate": {
          "type": "string",
          "description": "Human-readable constraint (e.g., '0 <= x <= 1')"
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "atlas_git_sha",
        "atlas_version",
        "demetrios_schema_version",
        "timestamp_utc",
        "pipeline_max",
        "pipeline_seed"
      ],
      "additionalProperties": true,
      "properties": {
        "assembly_accession": {"type": ["string", "null"]},
        "replicon_id": {"type": ["string", "null"]},
        "replicon_accession": {"type": ["string", "null"]},
        "length_bp": {"type": ["integer", "null"]},
        "window_length": {"type": ["integer", "null"]},
        "window_size": {"type": ["integer", "null"]},
        "k": {"type": ["integer", "null"]},
        "replichore": {"type": ["string", "null"]},
        "baseline_method": {"type": ["string", "null"]},
        "stem_min_length": {"type": ["integer", "null"]},
        "stem_max_length": {"type": ["integer", "null"]},
        "loop_min_length": {"type": ["integer", "null"]},
        "loop_max_length": {"type": ["integer", "null"]},
        "source_table": {"type": ["string", "null"]},
        "experiment_id": {
          "description": "Optional experiment identifier for experiment-scoped metrics",
          "oneOf": [
            {"type": "string"},
            {"type": "integer"},
            {"type": "null"}
          ]
        },
        "pipeline_max": {"type": "integer"},
        "pipeline_seed": {"type": "integer"},
        "atlas_git_sha": {"type": "string"},
        "atlas_version": {"type": "string"},
        "demetrios_schema_version": {"type": "string"},
        "timestamp_utc": {"type": "string", "format": "date-time"},
        "ncbi_filter": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "assembly_level": {"type": "string"},
            "source": {"type": "string"},
            "ftp_path": {"type": "string"},
            "version_status": {"type": "string"}
          }
        }
      }
    },
    "derivation": {
      "description": "Optional derivation/provenance graph edge(s) for no-miracles checks",
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "rule": {"type": ["string", "null"]},
        "derived_from": {
          "type": ["array", "null"],
          "items": {"type": "object"}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "record_type": {
            "enum": [
              "replicon_metric",
              "window_metric",
              "approx_symmetry",
              "kmer_metric",
              "skew_metric",
              "ir_metric",
              "replichore_metric"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "provenance": {
            "required": ["assembly_accession", "replicon_id"]
          }
        }
      }
    }
  ]
}
